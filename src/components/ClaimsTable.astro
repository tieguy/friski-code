---
import type { Subject } from '../content-schemas';
import { formatYmd } from '../lib/format-date';
interface Props {
  subject: Subject;
}
const { subject } = Astro.props;
---
<table>
  <thead>
    <tr>
      <th scope="col">Property</th>
      <th scope="col">Value</th>
      <th scope="col">Range</th>
      <th scope="col">Source</th>
    </tr>
  </thead>
  <tbody>
    {subject.claims.map((c) => (
      <tr>
        <td><code>{c.property}</code></td>
        <td><code>{c.value}</code></td>
        <td>
          {formatYmd(c.start) || '—'}
          {' → '}
          {c.end ? formatYmd(c.end) : (c.start ? 'present' : '—')}
        </td>
        <td><code>{c.source}</code></td>
      </tr>
    ))}
  </tbody>
</table>
