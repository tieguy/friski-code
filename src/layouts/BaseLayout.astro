---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Friski</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <header>
      <nav><a href="/">Friski</a></nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Friski — hyperlocal SF wiki.</p>
    </footer>
  </body>
</html>
